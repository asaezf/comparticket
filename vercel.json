{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/ticket.html", "destination": "/api/index.js" },
    { "source": "/claim.html", "destination": "/api/index.js" },
    { "source": "/summary.html", "destination": "/api/index.js" }
  ]
}
